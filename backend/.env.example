# Discord Bot Token - Get from https://discord.com/developers
# 1. Create Application → Bot → Reset Token
# 2. Enable: SERVER MEMBERS INTENT (in Bot settings)
# 3. Invite bot: OAuth2 → URL Generator → scopes: bot, guilds
DISCORD_BOT_TOKEN=your_bot_token_here

# Internal API token used by the Discord bot to update ingame names
BOT_INTERNAL_TOKEN=change_me_to_a_long_random_secret

# Discord OAuth2 - Get from OAuth2 Settings in Discord Developer Portal
# 1. Create Application (or use existing one with Bot)
# 2. Go to OAuth2 Settings → Add Redirect: http://localhost:3001/api/discord/oauth/callback
# 3. Copy Client ID and Client Secret
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/api/discord/oauth/callback

# Frontend URL for redirect after OAuth
FRONTEND_URL=http://localhost:3000

# Backend server port
PORT=3001

# PostgreSQL database
DATABASE_URL="postgresql://postgres:password@localhost:5432/gvg_manager?schema=public"