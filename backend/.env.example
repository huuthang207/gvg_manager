# Discord Bot Token - Get from https://discord.com/developers
# 1. Create Application → Bot → Reset Token
# 2. Enable: SERVER MEMBERS INTENT (in Bot settings)
# 3. Invite bot: OAuth2 → URL Generator → scopes: bot, guilds
DISCORD_BOT_TOKEN=your_bot_token_here

# Set to false on non-bot replicas so only one instance owns the Discord gateway client.
# Defaults to true when omitted.
DISCORD_BOT_ENABLED=true

# Internal API token used by the Discord bot to update ingame names
BOT_INTERNAL_TOKEN=change_me_to_a_long_random_secret

# Discord OAuth2 - Get from OAuth2 Settings in Discord Developer Portal
# 1. Create Application (or use existing one with Bot)
# 2. Go to OAuth2 Settings → Add Redirect URI matching DISCORD_REDIRECT_URI
# 3. Copy Client ID and Client Secret
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3001/api/discord/oauth/callback

# Fixed Discord server. On first login, ADMIN_DISCORD_USER_ID can provision this guild automatically.
FIXED_GUILD_DISCORD_ID=your_server_id_here
FIXED_GUILD_NAME=Your Guild Name
ADMIN_DISCORD_USER_ID=your_discord_user_id_here

# Frontend URL for redirect after OAuth
FRONTEND_URL=http://localhost:3000

# Comma-separated allowed browser origins for CORS. Defaults to FRONTEND_URL when omitted.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cookie settings. Leave SESSION_COOKIE_SAME_SITE unset to auto-use None for cross-origin frontend/backend URLs.
# Cross-origin HTTPS deploys require SESSION_COOKIE_SECURE=true and SameSite=None for mobile browsers.
SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SAME_SITE=Lax

# Backend server port
PORT=3001

# PostgreSQL database
DATABASE_URL="postgresql://postgres:password@localhost:5432/gvg_manager?schema=public"
