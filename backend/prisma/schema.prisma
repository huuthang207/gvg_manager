generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AttendanceChoice {
  GO
  MAYBE
  NOGO
}

enum AttendanceSessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AttendanceVoteJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum AttendanceType {
  GVG
  SCRIM
}

model User {
  id            String   @id @default(cuid())
  discordUserId String   @unique
  username      String
  globalName    String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guilds      Guild[]
  memberships GuildMembership[]
  sessions    Session[]
}

model Session {
  id                String   @id
  accessToken       String
  refreshToken      String
  expiresAt         DateTime
  userId            String
  activeGuildId     String?
  authBlockedReason String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Guild {
  id             String    @id @default(cuid())
  discordGuildId String    @unique
  name           String
  icon           String?
  ownerUserId    String
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  owner                   User                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members                 Member[]
  classRoleMappings       GuildClassRoleMapping[]
  requiredRoles           GuildRequiredRole[]
  accessRoles             GuildAccessRole[]
  memberships             GuildMembership[]
  attendanceChannelConfigs AttendanceChannelConfig[]
  attendanceSessions       AttendanceSession[]
  gvgParticipationSessions GvgParticipationSession[]
  gvgLineupDivisions       GvgLineupDivision[]
  gvgLineupSquads          GvgLineupSquad[]
}

model GvgLineupDivision {
  id         String   @id @default(cuid())
  guildId    String
  orderIndex Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  guild  Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  squads GvgLineupSquad[]

  @@unique([guildId, orderIndex])
  @@index([guildId])
}

model GvgLineupSquad {
  id           String   @id @default(cuid())
  guildId      String
  divisionId   String
  squadNumber  Int
  orderIndex   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guild    Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  division GvgLineupDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  slots    GvgLineupSlot[]

  @@unique([guildId, squadNumber])
  @@unique([divisionId, orderIndex])
  @@index([guildId])
  @@index([divisionId])
}

model GvgLineupSlot {
  id        String   @id @default(cuid())
  squadId   String
  slotIndex Int
  memberId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  squad  GvgLineupSquad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  member Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@unique([squadId, slotIndex])
  @@index([memberId])
}

model GuildAccessRole {
  id        String   @id @default(cuid())
  guildId   String
  roleName  String
  appRole   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, roleName, appRole])
  @@index([guildId, appRole])
}

model GvgParticipationSession {
  id                       String   @id @default(cuid())
  guildId                  String
  battleDate               DateTime
  battleCount              Int
  finalizedByDiscordUserId String?
  finalizedAt              DateTime @default(now())
  note                     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  guild   Guild                   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  entries GvgParticipationEntry[]

  @@unique([guildId, battleDate])
  @@index([guildId, battleDate])
}

model GvgParticipationEntry {
  id                 String   @id @default(cuid())
  sessionId          String
  memberId           String
  count              Int
  battleNumbers      Int[]    @default([])
  snapshotIngameName String?
  snapshotClassType  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  session GvgParticipationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member  Member                  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([memberId])
  @@index([sessionId])
}

model AttendanceChannelConfig {
  id               String         @id @default(cuid())
  guildId          String
  type             AttendanceType @default(GVG)
  discordChannelId String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, type])
  @@index([guildId, type])
}

model AttendanceSession {
  id                    String                  @id @default(cuid())
  guildId               String
  type                  AttendanceType          @default(GVG)
  status                AttendanceSessionStatus @default(OPEN)
  headerText            String?
  discordChannelId      String?
  discordMessageId      String?
  openedByDiscordUserId String?
  closedByDiscordUserId String?
  openedAt              DateTime                @default(now())
  closedAt              DateTime?
  lastRenderedAt        DateTime?
  lastVoteAt            DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  guild    Guild                @relation(fields: [guildId], references: [id], onDelete: Cascade)
  votes    AttendanceVote[]
  voteJobs AttendanceVoteJob[]

  @@index([guildId, type, status])
  @@index([guildId, type, openedAt])
}

model AttendanceVoteJob {
  id               String                  @id @default(cuid())
  sessionId        String
  guildId          String
  discordGuildId   String
  discordUserId    String
  discordMessageId String?
  type             AttendanceType          @default(GVG)
  choice           AttendanceChoice
  status           AttendanceVoteJobStatus @default(PENDING)
  attempts         Int                     @default(0)
  availableAt      DateTime                @default(now())
  lockedAt         DateTime?
  lockedBy         String?
  processedAt      DateTime?
  lastError        String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, discordUserId])
  @@index([status, availableAt, createdAt])
  @@index([sessionId, status, createdAt])
  @@index([guildId, status, availableAt])
}

model AttendanceVote {
  id                 String           @id @default(cuid())
  sessionId          String
  memberId           String
  choice             AttendanceChoice
  snapshotIngameName String?
  snapshotClassType  String?
  votedAt            DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  member  Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sessionId, memberId])
  @@index([sessionId, choice])
}

model GuildMembership {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([userId, role])
}

model GuildClassRoleMapping {
  id        String   @id @default(cuid())
  guildId   String
  classType String
  roleName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, classType])
}

model GuildRequiredRole {
  id        String   @id @default(cuid())
  guildId   String
  roleName  String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, roleName])
}

model Member {
  id                String    @id @default(cuid())
  guildId           String
  discordUserId     String
  username          String
  displayName       String
  ingameName        String?
  avatar            String?
  classType         String
  joinedAt          DateTime?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  guild                   Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roles                   MemberRole[]
  attendanceVotes         AttendanceVote[]
  gvgParticipationEntries GvgParticipationEntry[]
  gvgLineupSlots          GvgLineupSlot[]

  @@unique([guildId, discordUserId])
  @@index([guildId, active])
}

model MemberRole {
  id       String @id @default(cuid())
  memberId String
  roleName String

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}
